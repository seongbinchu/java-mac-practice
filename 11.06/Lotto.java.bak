import java.util.*;
class Lotto{
	public static void main(String[] args){
		Random r = new Random();
		HashSet<Integer> set = new HashSet<Integer>();
		while(set.size() != 6){
			set.add(r.nextInt(45)+1);
		}set.add(r.nextInt(45)+1);
		System.out.println(set);
	}
}

