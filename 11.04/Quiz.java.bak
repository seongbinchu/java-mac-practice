/*
	서점에 책장이 3개있고 각 책장에는 책이 10권 들어간다
*/
import java.util.Arrays;
class Quiz{
	
	public static void main(String[] args){
		String[][] bookCase = new String[3][10];
		bookCase[0][1]="JAVA";
		bookCase[0][9]="SPRING";
 		bookCase[2][5]="WEB";

		for(String[] temp : bookCase){
			System.out.println(Arrays.toString(temp));
		}
	}
}
