class Location{
	int x;
	int y;
	int z;

	public int getX(){
		return x;
	}
	public int getZ(){
		return z;
	}
	public int getY(){
		return y;
	}
	public void setX(int x){
		this.x=x;
	}
	public void setY(int y){
		this.y=y;
	}
	public void setZ(int z){
		this.z=z;
	}
	public Location(int x,int y,int z){
		setX(x);
		setY(y);
		setZ(z);
	}
}
