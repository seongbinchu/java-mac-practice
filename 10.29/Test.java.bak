    public void hold(Unit unit) { 
		System.out.println("ШІЕх"); 
	}
    public void patrol(Unit unit, Location a, Location b) {
        System.out.println("МјТћ");
    }
}

class MoveFly implements IMove {
	@Override
    public void move(Unit unit, Location destination) {
        //РхОжЙА ЙЋНУ Йз АЈМг , АЁМг
        unit.setLocation(destination);
    }
    public void stop(Unit unit) { 
		System.out.println(" КёЧр НКХО");
	}
    public void hold(Unit unit) {
		System.out.println("ШІЕх"); 
	}
    public void patrol(Unit unit, Location a, Location b) {
        System.out.println("МјТћ");
    }
}

