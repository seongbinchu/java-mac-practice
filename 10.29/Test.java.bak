abstract class Unit implements IMove,IAttack,IMagic{
    private UnitStataus stataus;
    private Location location;
    private IMove moveBehavior;
	private IAttack attackBehavior;
	private IMagic magicBehavior;
    private AttackPower groundAttackPower;
    private AttackPower airAttackPower;

    public Unit(UnitStataus stataus, Location location) {
        this.stataus = stataus;
        this.location =location;
    }

    public void setLocation(Location location) {
		this.location = location; 
	}
    public void setGroundAttackPower(AttackPower groundAttackPower) {
		this.groundAttackPower = groundAttackPower; 
	}
    public void setAirAttackPower(AttackPower airAttackPower) { 
		this.airAttackPower = airAttackPower; 
	}

    public UnitStataus getStataus() { 
		return stataus; 
	}
    public Location getLocation() { 
		return location; 
	}
    public AttackPower getGroundAttackPower() {
		return groundAttackPower;
	}
    public AttackPower getAirAttackPower() {
		return airAttackPower;
	}
    public boolean isFlying() { 
		return stataus.isFlying(); 
	}
	public void Move(Unit unit,Location destination) {
    }
    public void Stop(Unit unit) {
    }
    void Hold(Unit unit){
	}
    void Patrol(Unit unit,Location pointA,Location pointB){
	}

}

class Zealot extends Unit {
    
    public Zealot(Location location) {
        super(new Unitstataus(160, 1, 1.875, 7, false), location);
        setGroundAttackPower(new AttackPower(16, 1.0, 1));
        setAirAttackPower(null); 
        setAttackBehavior(new Attack()); 
        setMoveBehavior(new MoveWalk());
    }
    
    @Override 
	public void performAttack(Unit target) {
		attackBehavior.attack(this,target); 
	}
    @Override 
	public void performAttackMove(Location destination) {
		attackBehavior.attackMove(destination);
	}    
}
class Medic extends Unit {
    private Mana mana;
    private IMagic healBehavior;
    private IMagic dispelBehavior;
    private IMagic blindBehavior;

    public Medic(Location location) {
        super(new Unitstataus(60, 1, 1.875, 9, false), location);
        setMoveBehavior(new MoveWalk());
        this.mana = new Mana(200, 50);
        this.healBehavior = new MagicHeal();
        this.dispelBehavior = new MagicDispel();
        this.blindBehavior = new MagicBlind();
    }

    @Override 
	public Mana getMana() {
		return mana; 
	}

    public void performHeal(Unit target) {  
    }
    public void performDispel(Unit target) { 
    }
    public void performBlind(Unit target) { 
    }
    

}

class Mutalisk extends Unit{
    public Mutalisk(Location location) {
        super(new Unitstataus(120, 0, 3.75, 7, true), location);
        AttackPower attackPower = new AttackPower(9, 1.0, 3);
        setGroundAttackPower(attackPower);
        setAirAttackPower(attackPower);
        setAttackBehavior(new Attack()); 
        setMoveBehavior(new MoveFly());
    }

    @Override 
	public void performAttack(Unit target) {
		attackBehavior.attack(this, target); 
	}
    @Override 
	public void performAttackMove(Location destination) {
    }
    
    
}

