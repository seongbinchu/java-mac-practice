class Location {
    private int x;
    private int y;
    private int z;
    public Location(int x, int y, int z){
		this.x = x; 
		this.y = y; 
		this.z = z;
	}
    public int getX(){
		return x; 
	}
    public int getY() { 
		return y; 
	}
    public int getZ() {
		return z;
	}
    public void setX(int x) { 
		this.x = x; 
	}
    public void setY(int y) { 
		this.y = y;
	}
    public void setZ(int z) { 
		this.z = z; 
	}
}

class UnitStataus {
	private int hp;
	private int maxHp;
	private int amr;
	private double speed;
	private int sight;
	private boolean flying;

	public UnitStataus(int hp,int maxHp, int amr, double speed, int sight, boolean flying) {
        this.hp = hp;
		this.maxHp = maxHp;
        this.amr = amr;
        this.speed = speed;
        this.sight = sight;
        this.flying = flying;
    }

    public int getMaxHp() {
		return maxHp; 
	}
    public int getAmr() {
		return amr; 
	}
    public double getSpeed() { 
		return speed; 
	}
    public int getSight() { 
		return sight;
	}
    public boolean isFlying() { 
		return flying; 
	}
    public int getHp() { 
		return hp;
	}
    public void setHp(int hp) {
		//0КИДй ХЉАэ maxHpКИДй РлАХГЊ АААд}
	}

class AttackPower {
    private int damage;
    private double attackSpeed;
    private int range;

    public AttackPower(int damage, double attackSpeed, int range) {
        this.damage = damage;
        this.attackSpeed = attackSpeed;
        this.range = range;
    }

    public int getDamage() { 
		return damage; 
	}
    public double getAttackSpeed() { 
		return attackSpeed; 
	}
    public int getRange() { 
		return range; 
	}
}

class Mana {
    private int maxMana;
    private int mana;

    public Mana(int maxMana, int mana) {
        this.maxMana = maxMana;
        this.mana = mana;
    }

    public int getMaxMana() {
		return maxMana;
	}
    public int getMana() {
		return mana; 
	}

    public boolean canUse(int cost) {
		return mana >= cost;
	}
    public boolean use(int cost) {
        if (canUse(cost)) { 
			mana -= cost; 
			return true;
		}
        return false;
    }
    public void recoveryMana(int perMana) {
        //УЪДч ИЖГЊ ШИКЙ
    }
}

interface IMove {
    void move(Unit unit,Location destination);
    void stop(Unit unit);
    void hold(Unit unit);
    void patrol(Unit unit,Location pointA,Location pointB);
}

interface IAttack {
    void attack(Unit attacker, Unit target);
	void attackMove(Location destination);
}

interface IMagic {
    void cast(Unit caster, Unit target);
}


class MoveWalk implements IMove {
	@Override
