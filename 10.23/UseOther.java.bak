class Some{
	public int num =2;
}
//이름,사이즈,가격
class Other{
	Some s = new Some();

	public Some getS(){
		return s;
	}
	public void print(){
		System.out.println(s.num);
	}
}
// Items chunsik = "춘식","중",5000
// + 재고를 상주
class UseOther{
	public static void main(String[] args){
		Other o = new Other();
		Some another=o.getS();
		another.num=100;

		o.print();
	}
}
