/*
	상속 
	계층구조. 
	is - a 관계 必
X - A is-a
X - B is-a 될 때 X 생성

 A=>X<=B
X => 슈퍼클래스,부모클래스
A,B => 서브클래스,자식클래스
*/

class ParentObj {
	public int num = 2;

	public void todo(){
		System.out.println("Parent");
	}
}

// ChildObj가 ParentObj를 상속받는다
class ChildObj extends ParentObj{
	
}
class UseChildObj{
	public static void main(String[] args){
		ChildObj o = new ChildObj();
		System.out.println(o.num);
		o.todo();
	}
}