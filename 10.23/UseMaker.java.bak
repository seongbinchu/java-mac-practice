class Car{
	private String name;
	private int price=100;

	public int getPrice(){
		return price;
	}
	public String getName(){
		return name;
	}
	public void setName(){
		this.name = name;
	}
	public void setPrice(){
		this.price = price;
	}

	public Car(String name,int price){
		this.name=name;
		this.price=price;
	}
	public int plus(int p){
		this.price +=1000;
		return price;
	}
}
class Maker{
	Car c1 = new Car("car",3000);
	
}


