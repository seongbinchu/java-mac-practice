import java.util.*;
class Ball{
	private int num;

	public Ball(int num){
		setNum(num);
	}

	public int getNum(){
		return num;
	}
	public void setNum(int num){
		this.num=num;
	}
	@Override
	public String toString(){
		return "Ball("+num+")";
	}
	@Override
	public boolean equals(Object other){
		if(other == null || other instanceof Ball){
			return false;
		}
		Ball temp = (Ball)other;
		return num == temp.getNum();
	}
	
}

class ListEx1{
	public static void main(String[] args){

		Vector<Ball> vec = new Vector<Ball>();

		vec.add(new Ball(3));
		vec.add(new Ball(9));
		vec.add(new Ball(2));
		vec.add(new Ball(5));
		vec.add(new Ball(4));
		vec.add(new Ball(1));
		vec.add(new Ball(8));
		vec.add(new Ball(10));
		
		vec.remove(new Ball(4));

		System.out.println(vec);		// => 객체 주소값이 같은 Ball(4)없어서 제거안됨

		System.out.println(vec.indexOf(new Ball(4)));	//Obeject equals 객체 주소값 같은지 판단 => -1값나옴
	}
}
