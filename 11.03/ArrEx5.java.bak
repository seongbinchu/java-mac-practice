//น่ฟญภบ ฑโดษภฬ พ๘ดู.
//น่ฟญภฬ วา ผ๖ ภึดย ภฯต้ภป static class ฟก ธ๐พฦตะ ตตฟ์นฬ ลฌทกฝบ Arrays
import java.util.Arrays.*;
class ArrEx5{
	//int... nums = arr;
	//int[] nums = arr;
	public static void todo(int... nums){
		nums[0]=100;
	}
	
	
	public static void main(String[] args){
		int[] arr = {1,2,3};
		todo(arr);
		//1=>100 มถฝษ


		//for-eachนฎ // 0บฮลอ ณกฑ๎ม๖ =>ผ๘ศธ
		for(int n : arr){
			System.out.println(n);

			//for(int i=0;i<arr.length;i++)ฐ๚ภว ย๗ภฬมก
			//for-eachดย ภฮตฆฝบ ม๖มค บาฐก
			//for-eachดย ด๋ภิฟฌป๊ฟก บาธฎวฯดู
			//ผ๘ศธฟก ภฏธฎ
		String str = Arrays.toString(arr);
		System.out.println(str);
		}
	}
}
