/*case 1: RuntimeException extends
point 1 . Exception name
point 2 . exception or runtimeexception
point 3 . constructor
*/
class NotOverTen extends RuntimeException{
	public NotOverTen(String msg){
		super(msg);
	}
	public NotOverTen(){
		super("NotOverTen");
	}
	
}
class ExceptionEx2{
	public static void main(String[] args){
		try{
			int n = 0;
			while(true){
				n++;

				if(n>=0){
					NotOverTen e = new NotOverTen();
					throw e;
				}
			}
		}catch(NotOverTen e){
			System.out.println(e.getMessage());
		}
	System.out.println("end of main");
	}
}