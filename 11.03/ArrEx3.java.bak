class ArrEx3{

	public static void printSum(int num1,int num2,int num3){
		int sum = num1+num2+num3;
		System.out.println(sum);
	}

	public static void printSum2(int[] arr){
		int sum=0;
		for(int i=0;i<arr.length;i++){
			sum+=arr[i];
		}
		System.out.println(sum);
	}

	public static int[] getSumAndAverage(int[] nums){

		//합과 평균을 리턴받는 메소드
		int sum = 0;
		for(int i =0;i<nums.length;i++){
			sum+=nums[i];
		}
		int average = sum/ nums.length;
		return new int[] {sum,average};
	}
	public static final int SUM = 0;
	public static final int AVERAGE = 1;
	public static void main(String[] args){
		
		// 정수 3개를 받아 합을 구한다.
		

		printSum2(new int[] {5,4,2});
		printSum2(new int[] {5,4,2,4,5,6,43,21,12});
		int[] result = getSumAndAverage(new int[] {1,2,3,4,5,6,7,8,9});
		System.out.println("sum : " + result[SUM]);
		System.out.println("average : "+ result[AVERAGE]);
	}
}
